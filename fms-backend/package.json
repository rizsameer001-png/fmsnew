{
  "name": "fms-backend",
  "version": "1.0.0",
  "description": "Facility Management System - Complete Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed:admin": "node src/seeders/admin.seeder.js",
    "seed:buildings": "node src/seeders/building.seeder.js",
    "seed:services": "node src/seeders/services.seeder.js",
    "seed:roles": "node src/seeders/roles.seeder.js",
    "seed:all": "npm run seed:admin && npm run seed:buildings && npm run seed:services && npm run seed:roles",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "logs": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log"
  },
  "keywords": [
    "facility-management",
    "fms",
    "express",
    "mongodb",
    "socketio",
    "real-time",
    "gps-tracking",
    "attendance-system",
    "complaint-management"
  ],
  "author": "FMS Team",
  "license": "MIT",
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.3.41",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "firebase-admin": "^11.11.0",
    "helmet": "^7.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.5",
    "pdfkit": "^0.14.0",
    "razorpay": "^2.9.2",
    "socket.io": "^4.7.2",
    "twilio": "^4.19.3",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/fms-backend.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/fms-backend/issues"
  },
  "homepage": "https://github.com/yourusername/fms-backend#readme"
}
